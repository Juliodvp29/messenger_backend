# .env.example — versionar este archivo, NO el .env real
APP_ENV=development          # development | staging | production

# Base de datos
DATABASE__URL=postgres://messenger:messenger_secret@localhost:5434/messenger_dev
DATABASE__MAX_CONNECTIONS=20
DATABASE__MIN_CONNECTIONS=2

# Redis
REDIS__URL=redis://localhost:6379
REDIS__MAX_CONNECTIONS=20

# JWT — generar con: openssl rand -base64 64
JWT__SECRET=REEMPLAZAR_CON_64_BYTES_ALEATORIOS
JWT__REFRESH_SECRET=REEMPLAZAR_CON_64_BYTES_DISTINTOS
JWT__ACCESS_TTL_SECONDS=900        # 15 minutos
JWT__REFRESH_TTL_SECONDS=2592000   # 30 días

# Servidor
SERVER__HOST=0.0.0.0
SERVER__PORT=3000

# S3 / Storage
S3__ENDPOINT=http://localhost:9000
S3__BUCKET=messenger-attachments
S3__ACCESS_KEY_ID=minioadmin
S3__SECRET_ACCESS_KEY=minioadmin123
S3__REGION=us-east-1

# Email
SMTP__HOST=localhost
SMTP__PORT=1025
SMTP__FROM=noreply@messenger.local

# SMS (para OTP de registro y recuperación)
SMS__PROVIDER=twilio             # twilio | aws_sns
SMS__API_KEY=REEMPLAZAR
SMS__SENDER_ID=+1234567890

# Seguridad
SERVER__RATE_LIMIT_ENABLED=true
SERVER__CORS_ORIGINS=http://localhost:3001,http://localhost:19006
