# .env.example — Version this file, NOT the real .env
APP_ENV=development          # development | staging | production

# Database
DATABASE__URL=postgres://messenger:messenger_secret@localhost:5434/messenger_dev
DATABASE__MAX_CONNECTIONS=20
DATABASE__MIN_CONNECTIONS=2

# Redis
REDIS__URL=redis://localhost:6379
REDIS__MAX_CONNECTIONS=20

# JWT — Generate with: openssl genpkey -algorithm ed25519...
JWT__PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMC4CAQAwBQYDK2VwBCIEIPWCeU76Q422lF1aq5mjqE/nP/o8zEhF6gXX6Mzk9n+g\n-----END PRIVATE KEY-----"
JWT__PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMCowBQYDK2VwAyEA0IgiJOLeGDwumzkm+wi82nP7wvmbnaoWKmNNHMaq/Mw=\n-----END PUBLIC KEY-----"
JWT__ACCESS_TTL_SECONDS=86400
JWT__REFRESH_TTL_SECONDS=7776000

# Server
SERVER__HOST=0.0.0.0
SERVER__PORT=3000

# S3 / Storage
S3__ENDPOINT=http://localhost:9000
S3__BUCKET=messenger-attachments
S3__ACCESS_KEY_ID=minioadmin
S3__SECRET_ACCESS_KEY=minioadmin123
S3__REGION=us-east-1

# Email
SMTP__HOST=localhost
SMTP__PORT=1025
SMTP__FROM=noreply@messenger.local

# SMS (For registration OTP and recovery)
SMS__PROVIDER=twilio             # twilio | aws_sns
SMS__API_KEY=REPLACE_ME
SMS__SENDER_ID=+1234567890

# Security
SERVER__RATE_LIMIT_ENABLED=true
SERVER__CORS_ORIGINS=http://localhost:3001,http://localhost:19006

# Push Notifications
PUSH__APNS_BUNDLE_ID=com.messenger.app

# WebRTC / TURN (Optional, defaults to Google STUN servers)
# TURN__SECRET=replace_with_hmac_secret
# TURN__STUN_URLS="stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302"
# TURN__TURN_URLS="turn:your.server.com:3478"
# TURN__TTL_SECONDS=3600
