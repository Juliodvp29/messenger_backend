  "query": "\n            SELECT \n                id AS \"id!\", \n                username, \n                phone AS \"phone!\", \n                phone_hash AS \"phone_hash!\", \n                email, \n                status_text, \n                two_fa_enabled AS \"two_fa_enabled!\", \n                two_fa_secret, \n                is_active AS \"is_active!\", \n                last_seen_at, \n                created_at AS \"created_at!\", \n                updated_at AS \"updated_at!\", \n                deleted_at \n            FROM users \n            WHERE username = $1 AND deleted_at IS NULL\n            ",
