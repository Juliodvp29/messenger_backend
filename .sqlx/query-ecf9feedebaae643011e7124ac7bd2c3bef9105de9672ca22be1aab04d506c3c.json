  "db_name": "PostgreSQL",
  "query": "\n            SELECT \n                id AS \"id!\", \n                owner_id AS \"owner_id!\", \n                contact_id, \n                phone AS \"phone!\", \n                nickname, \n                is_favorite AS \"is_favorite!\", \n                created_at AS \"created_at!\"\n            FROM contacts\n            WHERE owner_id = $1 AND is_favorite = TRUE\n            ORDER BY nickname ASC, phone ASC\n            ",
