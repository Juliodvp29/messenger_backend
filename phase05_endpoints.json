{
  "info": {
    "name": "Messenger Backend - Phase 05 Chats & Messages",
    "description": "Fase 05: Chats y Mensajes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "chat_id", "value": "" },
    { "key": "message_id", "value": "" },
    { "key": "participant_id", "value": "" },
    { "key": "cursor", "value": "" }
  ],
  "item": [
    {
      "name": "Chats",
      "item": [
        {
          "name": "POST /chats (Private)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/chats",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"private\",\n  \"participant_id\": \"{{participant_id}}\"\n}"
            }
          }
        },
        {
          "name": "POST /chats (Group)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/chats",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"group\",\n  \"name\": \"Group Name\",\n  \"participant_ids\": [\"uuid1\", \"uuid2\", \"uuid3\"]\n}"
            }
          }
        },
        {
          "name": "GET /chats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/chats?limit=20",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ]
          }
        },
        {
          "name": "GET /chats (with cursor)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/chats?cursor={{cursor}}&limit=20",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ]
          }
        },
        {
          "name": "GET /chats/:id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/chats/{{chat_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ]
          }
        },
        {
          "name": "PATCH /chats/:id",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/chats/{{chat_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Chat Name\",\n  \"avatar_url\": \"https://example.com/avatar.jpg\"\n}"
            }
          }
        },
        {
          "name": "DELETE /chats/:id",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/chats/{{chat_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "POST /chats/:id/messages",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/chats/{{chat_id}}/messages",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content_encrypted\": \"base64_encrypted_content\",\n  \"content_iv\": \"base64_iv\",\n  \"message_type\": \"text\",\n  \"reply_to_id\": null,\n  \"is_forwarded\": false\n}"
            }
          }
        },
        {
          "name": "GET /chats/:id/messages",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/chats/{{chat_id}}/messages?limit=50&direction=before",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ]
          }
        },
        {
          "name": "GET /chats/:id/messages (with cursor)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/chats/{{chat_id}}/messages?cursor={{cursor}}&limit=50&direction=before",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ]
          }
        },
        {
          "name": "PATCH /chats/:id/messages/:msg_id",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/chats/{{chat_id}}/messages/{{message_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content_encrypted\": \"new_base64_encrypted\",\n  \"content_iv\": \"new_base64_iv\"\n}"
            }
          }
        },
        {
          "name": "DELETE /chats/:id/messages/:msg_id",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/chats/{{chat_id}}/messages/{{message_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ]
          }
        },
        {
          "name": "POST /chats/:id/messages/read",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/chats/{{chat_id}}/messages/read",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"up_to\": \"2024-01-15T10:30:00Z\"\n}"
            }
          }
        },
        {
          "name": "POST /chats/:id/messages/:msg_id/reactions",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/chats/{{chat_id}}/messages/{{message_id}}/reactions",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reaction\": \"👍\"\n}"
            }
          }
        },
        {
          "name": "DELETE /chats/:id/messages/:msg_id/reactions/:emoji",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/chats/{{chat_id}}/messages/{{message_id}}/reactions/%F0%9F%91%8D",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ]
          }
        },
        {
          "name": "POST /chats/:id/messages/:msg_id/reactions/remove (Alternative)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/chats/{{chat_id}}/messages/{{message_id}}/reactions/remove",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reaction\": \"👍\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Attachments",
      "item": [
        {
          "name": "POST /attachments/upload-url",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/attachments/upload-url",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"file_type\": \"image/jpeg\",\n  \"file_size\": 1048576,\n  \"chat_id\": \"{{chat_id}}\"\n}"
            }
          }
        },
        {
          "name": "POST /attachments/confirm",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/attachments/confirm",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"attachment_id\": \"uuid-from-upload-url\",\n  \"message_id\": \"uuid-for-message\",\n  \"encryption_key_enc\": \"base64\",\n  \"encryption_iv\": \"base64\"\n}"
            }
          }
        }
      ]
    }
  ]
}