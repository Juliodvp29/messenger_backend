# ==========================================
# VARIABLES DEL SERVIDOR CLOUD (VPS)
# ==========================================
# DOMINIO: Reemplaza por tu dominio cuando lo compres (ej: api.messenger.com)
# Si aún no tienes dominio, puedes poner la IP del servidor pero ten en cuenta las
# configuraciones relacionadas a HTTPS/TLS en el Caddyfile.
DOMAIN=tu-dominio-o-ip.com

# ==========================================
# CREDENCIALES DE INFRAESTRUCTURA (REEMPLAZAR TODO ANTES DE DESPLEGAR)
# ==========================================
# PostgreSQL
DB_NAME=messenger_prod
DB_USER=messenger
DB_PASSWORD=CAMBIAME_POR_UN_PASSWORD_SEGURO_PARA_BD

# Redis
REDIS_PASSWORD=CAMBIAME_POR_UN_PASSWORD_SEGURO_PARA_REDIS

# MinIO (S3 Local)
S3_ROOT_USER=minioadmin
S3_ROOT_PASSWORD=CAMBIAME_POR_UN_PASSWORD_SEGURO_PARA_MINIO

# ==========================================
# CONFIGURACIÓN DE LA APLICACIÓN RUST
# ==========================================
APP_ENV=production

# Base de datos (Debe coincidir con las credenciales de arriba)
DATABASE__URL=postgres://messenger:CAMBIAME_POR_UN_PASSWORD_SEGURO_PARA_BD@postgres:5432/messenger_prod
DATABASE_URL=postgres://messenger:CAMBIAME_POR_UN_PASSWORD_SEGURO_PARA_BD@postgres:5432/messenger_prod
DATABASE__MAX_CONNECTIONS=50
DATABASE__MIN_CONNECTIONS=5

# Redis (Debe coincidir con el password de arriba)
REDIS__URL=redis://:CAMBIAME_POR_UN_PASSWORD_SEGURO_PARA_REDIS@redis:6379
REDIS__MAX_CONNECTIONS=50

# S3 (Apunta al contenedor de MinIO interno)
S3__ENDPOINT=http://minio:9000
S3__BUCKET=messenger-prod-attachments
S3__ACCESS_KEY_ID=minioadmin
S3__SECRET_ACCESS_KEY=CAMBIAME_POR_UN_PASSWORD_SEGURO_PARA_MINIO
S3__REGION=us-east-1

# JWT — MUY IMPORTANTE: Generar nuevas claves para producción
# Para generar claves asimétricas Ed25519 ejecuta en tu terminal:
# openssl genpkey -algorithm ed25519 -out private.pem
# openssl pkey -in private.pem -pubout -out public.pem
JWT__PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCAMBIAME\n-----END PRIVATE KEY-----"
JWT__PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nCAMBIAME\n-----END PUBLIC KEY-----"
JWT__ACCESS_TTL_SECONDS=3600
JWT__REFRESH_TTL_SECONDS=604800

# Servidor 
SERVER__HOST=0.0.0.0
SERVER__PORT=3000

# Seguridad CORS (Añade el dominio de tu frontend o app aquí)
SERVER__CORS_ORIGINS=https://mi-dominio.com,http://localhost:3000
SERVER__RATE_LIMIT_ENABLED=true
