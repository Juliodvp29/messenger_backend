# ==========================================
# CLOUD SERVER (VPS) VARIABLES
# ==========================================
# DOMAIN: Replace with your domain when acquired (e.g. api.messenger.com)
# If you don't have a domain yet, you can put the server IP, but note
# the HTTPS/TLS related configurations in the Caddyfile.
DOMAIN=your-domain-or-ip.com

# ==========================================
# INFRASTRUCTURE CREDENTIALS (REPLACE ALL BEFORE DEPLOYING)
# ==========================================
# PostgreSQL
DB_NAME=messenger_prod
DB_USER=messenger
DB_PASSWORD=CHANGE_ME_FOR_A_SECURE_DB_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_FOR_A_SECURE_REDIS_PASSWORD

# MinIO (Local S3)
S3_ROOT_USER=minioadmin
S3_ROOT_PASSWORD=CHANGE_ME_FOR_A_SECURE_MINIO_PASSWORD

# ==========================================
# RUST APPLICATION CONFIGURATION
# ==========================================
APP_ENV=production

# Database (Must match the credentials above)
DATABASE__URL=postgres://messenger:CHANGE_ME_FOR_A_SECURE_DB_PASSWORD@postgres:5432/messenger_prod
DATABASE_URL=postgres://messenger:CHANGE_ME_FOR_A_SECURE_DB_PASSWORD@postgres:5432/messenger_prod
DATABASE__MAX_CONNECTIONS=50
DATABASE__MIN_CONNECTIONS=5

# Redis (Must match the password above)
REDIS__URL=redis://:CHANGE_ME_FOR_A_SECURE_REDIS_PASSWORD@redis:6379
REDIS__MAX_CONNECTIONS=50

# S3 (Points to internal MinIO container)
S3__ENDPOINT=http://minio:9000
S3__BUCKET=messenger-prod-attachments
S3__ACCESS_KEY_ID=minioadmin
S3__SECRET_ACCESS_KEY=CHANGE_ME_FOR_A_SECURE_MINIO_PASSWORD
S3__REGION=us-east-1

# JWT — VERY IMPORTANT: Generate new keys for production
# To generate Ed25519 asymmetric keys run in your terminal:
# openssl genpkey -algorithm ed25519 -out private.pem
# openssl pkey -in private.pem -pubout -out public.pem
JWT__PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----"
JWT__PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nCHANGE_ME\n-----END PUBLIC KEY-----"
JWT__ACCESS_TTL_SECONDS=3600
JWT__REFRESH_TTL_SECONDS=604800

# Server 
SERVER__HOST=0.0.0.0
SERVER__PORT=3000

# CORS Security (Add your frontend or app domain here)
SERVER__CORS_ORIGINS=https://my-domain.com,http://localhost:3000
SERVER__RATE_LIMIT_ENABLED=true
